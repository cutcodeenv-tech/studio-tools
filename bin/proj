#!/bin/zsh

# ── КОНФИГ ──────────────────────────────────────────────────────────────────
SSD_PROJECTS_ROOT="/Volumes/01_Extreme SSD/[001] Projects"
HDD_SOURCES_ROOT="/Volumes/HDD_1"
PREMIERE_TEMPLATE="/Volumes/01_Extreme SSD/[003] Resurces/00_TEMPLATE1.prproj"
STUDIO_DIR="$HOME/.studio-tools"
_UPDATE_FILE="${STUDIO_DIR}/.update_available"
_UPDATE_CACHE="${STUDIO_DIR}/.update_cache"
# ────────────────────────────────────────────────────────────────────────────

# ── CLI: proj update ─────────────────────────────────────────────────────────
if [[ "$1" == "update" ]]; then
    print -P "\n%B%F{cyan}Обновление Studio Tools...%f%b\n"
    if git -C "$STUDIO_DIR" pull; then
        cp "${STUDIO_DIR}/bin/proj" "$HOME/bin/proj" && chmod +x "$HOME/bin/proj"
        rm -f "$_UPDATE_FILE"
        local_ver=$(git -C "$STUDIO_DIR" rev-parse --short HEAD 2>/dev/null)
        print -P "\n%F{green}%B✅ Обновлено до ${local_ver}. Перезапусти proj.%f%b\n"
    else
        print -P "\n%F{red}✗ Ошибка обновления%f\n"
    fi
    exit 0
fi

# ── ПРОГРЕСС-БАР КОПИРОВАНИЯ ─────────────────────────────────────────────────
copy_with_progress() {
    local src="$1" dst="$2" label="$3"
    local total=$(stat -f%z "$src" 2>/dev/null || echo 1)
    local bar_width=30

    cp "$src" "$dst" &
    local cp_pid=$!

    while kill -0 $cp_pid 2>/dev/null; do
        local current=$(stat -f%z "$dst" 2>/dev/null || echo 0)
        local pct=$(( current * 100 / total ))
        local filled=$(( pct * bar_width / 100 ))
        local bar=""
        for (( j=0; j<bar_width; j++ )); do
            (( j < filled )) && bar+="█" || bar+="░"
        done
        printf "\r  \033[33m⬇\033[0m  \033[90m[%s]\033[0m %3d%%  %s" "$bar" "$pct" "$label"
        sleep 0.15
    done

    wait $cp_pid
    local status=$?
    local full_bar=$(printf '█%.0s' {1..$bar_width})
    if (( status == 0 )); then
        printf "\r  \033[32m✓\033[0m  \033[90m[%s]\033[0m 100%%  %s\n" "$full_bar" "$label"
    else
        printf "\r  \033[31m✗\033[0m  копирование не удалось: %s\n" "$label"
    fi
    return $status
}

# ── ФАЙЛОВЫЙ МЕНЕДЖЕР ────────────────────────────────────────────────────────
proj_file_manager() {
    local current_dir="$SSD_PROJECTS_ROOT"
    local _act_f _mod_f
    _act_f=$(mktemp); _mod_f=$(mktemp)

    # Эти биндинги не меняются между итерациями — задаём один раз
    local _del_t _bsp_t
    _del_t="transform:[[ \$(cat ${_mod_f}) == 1 ]] && echo 'delete-char' || echo 'execute-silent(echo d > ${_act_f})+accept'"
    _bsp_t="transform:[[ \$(cat ${_mod_f}) == 1 ]] && echo 'backward-delete-char' || echo 'execute-silent(echo d > ${_act_f})+accept'"

    while true; do
        # Список содержимого папки
        local items=()
        [[ "$current_dir" != "$SSD_PROJECTS_ROOT" ]] && items+=("↑  ..")
        for item in "${current_dir}"/*(N); do
            local base=$(basename "$item")
            [[ -d "$item" ]] && items+=("▶  ${base}") || items+=("   ${base}")
        done

        # Путь и метка для отображения
        local rel="${current_dir#${SSD_PROJECTS_ROOT}}"
        [[ -z "$rel" ]] && rel="/"
        local dir_name=$(basename "$current_dir")
        [[ "$current_dir" == "$SSD_PROJECTS_ROOT" ]] && dir_name="Проекты"

        # Сброс флагов для каждой сессии fzf
        : > "$_act_f"; echo 0 > "$_mod_f"

        # Биндинги поиска зависят от текущего пути — пересчитываем
        local _son _soff _ctrlf
        _son="enable-search+change-prompt(  ${rel} / )+change-header(  ── поиск ──   Del/⌫: стереть   Ctrl+F: выйти из поиска)"
        _soff="disable-search+clear-query+change-prompt(  ${rel} > )+change-header(  Space: выбрать   Enter/→: войти   Ctrl+R: переим.   ←: вверх   Ctrl+F: поиск)"
        _ctrlf="transform:[[ \$(cat ${_mod_f}) == 0 ]] && { echo 1 > ${_mod_f}; echo '${_son}'; } || { echo 0 > ${_mod_f}; echo '${_soff}'; }"

        local result
        result=$(printf '%s\n' "${items[@]}" | fzf \
            --prompt="  ${rel} > " \
            --height=50% \
            --layout=reverse \
            --border=rounded \
            --border-label=" ${dir_name} " \
            --color="border:#5fafff,label:#5fafff,prompt:#5fafff,pointer:#ff875f" \
            --pointer="▶" \
            --multi \
            --disabled \
            --bind="space:toggle" \
            --bind="right:accept" \
            --bind="del:${_del_t}" \
            --bind="bspace:${_bsp_t}" \
            --bind="ctrl-f:${_ctrlf}" \
            --expect="left,ctrl-r" \
            --header="  Space: выбрать   Enter/→: войти   Ctrl+R: переим.   ←: вверх   Ctrl+F: поиск")

        [[ -z "$result" ]] && break

        local lines=("${(@f)result}")
        local key="${lines[1]}"
        local selections=("${lines[2,-1]}")
        local is_delete=false
        [[ -s "$_act_f" ]] && is_delete=true

        # ── Стрелка влево / ← — подняться выше ──────────────────────────────
        if [[ "$key" == "left" ]]; then
            [[ "$current_dir" != "$SSD_PROJECTS_ROOT" ]] && current_dir="${current_dir:h}"

        # ── Del / ⌫ — удаление ───────────────────────────────────────────────
        elif $is_delete; then
            local del_items=()
            for s in "${selections[@]}"; do
                local n="${s[4,-1]}"
                [[ "$n" == ".." ]] && continue
                del_items+=("${current_dir}/${n}")
            done
            [[ ${#del_items[@]} -eq 0 ]] && continue

            print -P "\n%B%F{red}Переместить в корзину:%f%b"
            for p in "${del_items[@]}"; do
                print -P "  %F{red}✗%f  $(basename "$p")"
            done
            print -P "\n%F{yellow}Подтвердить? [y/N]: \c"
            read CONFIRM
            if [[ "$CONFIRM" == "y" || "$CONFIRM" == "Y" ]]; then
                for p in "${del_items[@]}"; do
                    if osascript -e "tell application \"Finder\" to delete POSIX file \"${p}\"" 2>/dev/null; then
                        print -P "  %F{green}✓%f  $(basename "$p") → Корзина"
                    else
                        print -P "  %F{red}✗%f  Не удалось: $(basename "$p")"
                    fi
                done
            else
                print -P "%F{red}Отменено.%f"
            fi
            print ""

        # ── Ctrl+R — переименование ───────────────────────────────────────────
        elif [[ "$key" == "ctrl-r" ]]; then
            local ren_items=()
            for s in "${selections[@]}"; do
                local n="${s[4,-1]}"
                [[ "$n" == ".." ]] && continue
                ren_items+=("$n")
            done
            [[ ${#ren_items[@]} -eq 0 ]] && continue

            if [[ ${#ren_items[@]} -eq 1 ]]; then
                local old_name="${ren_items[1]}"
                print -P "\n%B%F{cyan}Переименовать:%f%b ${old_name}"
                print -P "%B%F{cyan}│%f%b Новое имя: \c"
                read new_name
                if [[ -n "$new_name" && "$new_name" != "$old_name" ]]; then
                    if mv "${current_dir}/${old_name}" "${current_dir}/${new_name}" 2>/dev/null; then
                        print -P "  %F{green}✓%f  ${old_name} → ${new_name}"
                    else
                        print -P "  %F{red}✗%f  Не удалось переименовать"
                    fi
                fi
                print ""
            else
                local ren_action
                ren_action=$(printf "1  Найти и заменить\n2  Добавить префикс\n3  Добавить суффикс" | fzf \
                    --prompt="  > " \
                    --height=8 \
                    --layout=reverse \
                    --border=rounded \
                    --border-label=" Переименовать ${#ren_items[@]} объектов " \
                    --color="border:#5fafff,label:#5fafff,prompt:#5fafff,pointer:#ff875f" \
                    --pointer="▶" --no-multi)
                [[ -z "$ren_action" ]] && continue

                print -P "\n%B%F{cyan}Переименование: ${#ren_items[@]} объектов%f%b"
                case "$ren_action" in
                    *"Найти и заменить"*)
                        print -P "%B%F{cyan}│%f%b Найти: \c";    read find_str
                        print -P "%B%F{cyan}│%f%b Заменить: \c"; read repl_str
                        for old in "${ren_items[@]}"; do
                            local new="${old//${find_str}/${repl_str}}"
                            if [[ "$new" != "$old" ]]; then
                                mv "${current_dir}/${old}" "${current_dir}/${new}" 2>/dev/null && \
                                    print -P "  %F{green}✓%f  ${old} → ${new}" || \
                                    print -P "  %F{red}✗%f  ${old}"
                            else
                                print -P "  %F{yellow}–%f  ${old} (без изменений)"
                            fi
                        done ;;
                    *"Добавить префикс"*)
                        print -P "%B%F{cyan}│%f%b Префикс: \c"; read prefix
                        for old in "${ren_items[@]}"; do
                            mv "${current_dir}/${old}" "${current_dir}/${prefix}${old}" 2>/dev/null && \
                                print -P "  %F{green}✓%f  ${old} → ${prefix}${old}" || \
                                print -P "  %F{red}✗%f  ${old}"
                        done ;;
                    *"Добавить суффикс"*)
                        print -P "%B%F{cyan}│%f%b Суффикс (перед расширением): \c"; read suffix
                        for old in "${ren_items[@]}"; do
                            if [[ "$old" == *.* ]]; then
                                local new="${old%.*}${suffix}.${old##*.}"
                            else
                                local new="${old}${suffix}"
                            fi
                            mv "${current_dir}/${old}" "${current_dir}/${new}" 2>/dev/null && \
                                print -P "  %F{green}✓%f  ${old} → ${new}" || \
                                print -P "  %F{red}✗%f  ${old}"
                        done ;;
                esac
                print ""
            fi

        # ── Enter / → — войти в папку или открыть файл ──────────────────────
        else
            local first="${selections[1]}"
            [[ -z "$first" ]] && continue
            local fname="${first[4,-1]}"

            if [[ "$fname" == ".." ]]; then
                [[ "$current_dir" != "$SSD_PROJECTS_ROOT" ]] && current_dir="${current_dir:h}"
            elif [[ "$first" == "▶"* ]]; then
                current_dir="${current_dir}/${fname}"
            else
                for s in "${selections[@]}"; do
                    local n="${s[4,-1]}"
                    open "${current_dir}/${n}"
                done
            fi
        fi
    done

    rm -f "$_act_f" "$_mod_f"
}

# ── ВЕРСИЯ И ПРОВЕРКА ОБНОВЛЕНИЙ ─────────────────────────────────────────────
PROJ_VERSION=$(git -C "$STUDIO_DIR" rev-parse --short HEAD 2>/dev/null || echo "?")

# Фоновая проверка раз в 6 часов — не блокирует запуск
(
    if [[ ! -f "$_UPDATE_CACHE" ]] || \
       (( $(date +%s) - $(stat -f%m "$_UPDATE_CACHE" 2>/dev/null || echo 0) > 21600 )); then
        touch "$_UPDATE_CACHE"
        if git -C "$STUDIO_DIR" fetch origin main --quiet 2>/dev/null; then
            behind=$(git -C "$STUDIO_DIR" rev-list HEAD..origin/main --count 2>/dev/null)
            if (( behind > 0 )); then
                echo "$behind" > "$_UPDATE_FILE"
            else
                rm -f "$_UPDATE_FILE"
            fi
        fi
    fi
) &>/dev/null &

# ── ГЛАВНЫЙ ЦИКЛ ─────────────────────────────────────────────────────────────
print -P "%F{240}  Ctrl+C для выхода%f"

while true; do

# ── МЕНЮ ────────────────────────────────────────────────────────────────────
_MENU="1  Новый проект\n2  Проекты\n3  Статус проекта\n4  Синхронизировать footage"
if [[ -f "$_UPDATE_FILE" ]]; then
    _behind=$(cat "$_UPDATE_FILE")
    _MENU+="\\n5  ⬆  Обновить  (${_behind} новых коммит(а))"
fi

action=$(printf "$_MENU" | fzf \
    --prompt="  > " \
    --height=12 \
    --layout=reverse \
    --border=rounded \
    --border-label=" proj ${PROJ_VERSION} " \
    --color="border:#5fafff,label:#5fafff,prompt:#5fafff,pointer:#ff875f" \
    --pointer="▶" \
    --no-multi)

[[ -z "$action" ]] && continue

# ── НОВЫЙ ПРОЕКТ ─────────────────────────────────────────────────────────────
if [[ "$action" == *"Новый проект"* ]]; then

    print -P "\n%B%F{cyan}┌─ Новый проект ─────────────────────────┐%f%b"

    print -P "%B%F{cyan}│%f%b Название: \c"
    read PROJECT_NAME
    if [[ -z "$PROJECT_NAME" ]]; then
        print -P "%F{red}Отменено.%f\n"
        continue
    fi

    print -P "%B%F{cyan}│%f%b Камер (1-10) [2]: \c"
    read CAM_COUNT
    if ! [[ "$CAM_COUNT" =~ ^[0-9]+$ ]] || (( CAM_COUNT < 1 || CAM_COUNT > 10 )); then
        CAM_COUNT=2
    fi

    print -P "%B%F{cyan}└────────────────────────────────────────┘%f%b"

    DATE=$(date +%Y-%m-%d)
    SAFE_NAME="${PROJECT_NAME// /_}"
    PROJECT_FOLDER_NAME="${DATE}_${SAFE_NAME}"
    SSD_ROOT="${SSD_PROJECTS_ROOT}/${PROJECT_FOLDER_NAME}"
    HDD_ROOT="${HDD_SOURCES_ROOT}/${PROJECT_FOLDER_NAME}"

    if [[ -d "$SSD_ROOT" ]]; then
        print -P "\n%F{red}✗ Папка уже существует: ${SSD_ROOT}%f\n"
        continue
    fi

    print -P "\n%F{yellow}Создаю структуру...%f"

    mkdir -p "${SSD_ROOT}/00_Admin"
    mkdir -p "${SSD_ROOT}/01_Project_Files"/{Premiere,DaVinci,AfterEffects,Photoshop,Illustrator,Audition}
    mkdir -p "${SSD_ROOT}/02_Sources"/{Video/{Screen_Cap,Stock_Archival},Audio/{Music,SFX,VoiceOver},Graphics/{Images,Vectors}}
    mkdir -p "${SSD_ROOT}/03_Proxies"
    mkdir -p "${SSD_ROOT}/04_Exports"/{01_Drafts,02_Handoff/{For_Color,For_Sound,For_CGI},03_Master,04_Socials}
    mkdir -p "${SSD_ROOT}/99_Archive"
    print -P "  %F{green}✓%f  Папки SSD"

    if [[ -f "$PREMIERE_TEMPLATE" ]]; then
        cp "$PREMIERE_TEMPLATE" "${SSD_ROOT}/01_Project_Files/Premiere/${SAFE_NAME}.prproj"
        print -P "  %F{green}✓%f  Шаблон Premiere"
    else
        print -P "  %F{yellow}⚠%f  Шаблон Premiere не найден"
    fi

    if [[ ! -d "$HDD_SOURCES_ROOT" ]]; then
        print -P "  %F{yellow}⚠%f  HDD не смонтирован, камеры пропущены"
    else
        ALPHABET=( {a..z} )
        for (( i=1; i<=CAM_COUNT; i++ )); do
            CAM="Cam_${ALPHABET[$i]}"
            mkdir -p "${SSD_ROOT}/02_Sources/Video/${CAM}/Proxy"
            mkdir -p "${HDD_ROOT}/02_Sources/Video/${CAM}"
            print -P "  %F{green}✓%f  ${CAM}"
        done
    fi

    print -P "\n%F{green}%B✅ Готово:%b ${SSD_ROOT}%f"
    print -P "%F{cyan}│%f Открыть в Finder? [Y/n]: \c"
    read OPEN_FINDER
    if [[ "$OPEN_FINDER" != "n" && "$OPEN_FINDER" != "N" ]]; then
        open "$SSD_ROOT"
    fi
    print ""

# ── ПРОЕКТЫ ──────────────────────────────────────────────────────────────────
elif [[ "$action" == *"Проекты"* ]]; then

    proj_file_manager

# ── СТАТУС ПРОЕКТА ────────────────────────────────────────────────────────────
elif [[ "$action" == *"Статус проекта"* ]]; then

    chosen=$(ls -1t "$SSD_PROJECTS_ROOT" 2>/dev/null | fzf \
        --prompt="  Проект > " \
        --height=40% \
        --border=rounded \
        --border-label=" Статус проекта " \
        --color="border:#5fafff,label:#5fafff,prompt:#5fafff,pointer:#ff875f" \
        --pointer="▶" \
        --no-multi)

    [[ -z "$chosen" ]] && continue

    SSD_PROJECT="${SSD_PROJECTS_ROOT}/${chosen}"
    HDD_PROJECT="${HDD_SOURCES_ROOT}/${chosen}"

    print -P "\n%B%F{cyan}┌─ ${chosen}%f%b"

    total_hdd=0
    total_symlinks=0
    total_proxies=0

    for ssd_cam in "${SSD_PROJECT}/02_Sources/Video"/Cam_*/; do
        [[ -d "$ssd_cam" ]] || continue
        cam_name=$(basename "$ssd_cam")
        hdd_cam="${HDD_PROJECT}/02_Sources/Video/${cam_name}"

        ssd_links=$(find "$ssd_cam" -maxdepth 1 -type l | wc -l | tr -d ' ')
        hdd_files=0
        [[ -d "$hdd_cam" ]] && hdd_files=$(find "$hdd_cam" -maxdepth 1 -type f | wc -l | tr -d ' ')
        proxy_count=$(find "${ssd_cam}Proxy" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')

        (( total_hdd += hdd_files ))
        (( total_symlinks += ssd_links ))
        (( total_proxies += proxy_count ))

        if (( hdd_files > 0 && ssd_links == hdd_files )); then
            icon="%F{green}✓%f"
        elif (( ssd_links > 0 )); then
            icon="%F{yellow}~%f"
        else
            icon="%F{red}○%f"
        fi

        print -P "%B%F{cyan}│%f%b  ${icon}  ${cam_name}   HDD: ${hdd_files}   симлинки: ${ssd_links}   прокси: ${proxy_count}"
    done

    ssd_size=$(du -sh "$SSD_PROJECT" 2>/dev/null | cut -f1)
    print -P "%B%F{cyan}│%f%b"
    print -P "%B%F{cyan}│%f%b  SSD: ${ssd_size}   всего исходников: ${total_hdd}   симлинков: ${total_symlinks}   прокси: ${total_proxies}"
    print -P "%B%F{cyan}└────────────────────────────────────────┘%f%b\n"

# ── SYNC FOOTAGE ─────────────────────────────────────────────────────────────
elif [[ "$action" == *"Синхронизировать footage"* ]]; then

    print -P "\n%B%F{cyan}Sync Footage%f%b\n"

    if [[ ! -d "$HDD_SOURCES_ROOT" ]]; then
        print -P "%F{red}✗ HDD не смонтирован: ${HDD_SOURCES_ROOT}%f\n"
        continue
    fi

    chosen=$(ls -1t "$SSD_PROJECTS_ROOT" 2>/dev/null | fzf \
        --prompt="  Проект > " \
        --height=40% \
        --border=rounded \
        --border-label=" Выберите проект " \
        --color="border:#5fafff,label:#5fafff,prompt:#5fafff,pointer:#ff875f" \
        --pointer="▶" \
        --no-multi)

    if [[ -z "$chosen" ]]; then
        print -P "%F{red}Отменено.%f\n"
        continue
    fi

    SSD_PROJECT="${SSD_PROJECTS_ROOT}/${chosen}"
    HDD_PROJECT="${HDD_SOURCES_ROOT}/${chosen}"

    if [[ ! -d "$HDD_PROJECT" ]]; then
        print -P "%F{red}✗ Проект не найден на HDD: ${HDD_PROJECT}%f\n"
        continue
    fi

    print -P "%B▶ Проект:%b ${chosen}\n"

    synced=0
    skipped=0

    for hdd_cam in "${HDD_PROJECT}/02_Sources/Video"/Cam_*/; do
        [[ -d "$hdd_cam" ]] || continue
        cam_name=$(basename "$hdd_cam")
        ssd_cam="${SSD_PROJECT}/02_Sources/Video/${cam_name}"

        mkdir -p "${ssd_cam}/Proxy"
        print -P "%B%F{cyan}📁 ${cam_name}%f%b"

        for hdd_file in "${hdd_cam}"*; do
            [[ -f "$hdd_file" ]] || continue
            filename=$(basename "$hdd_file")
            ssd_link="${ssd_cam}/${filename}"

            if [[ ! -e "$ssd_link" && ! -L "$ssd_link" ]]; then
                ln -s "$hdd_file" "$ssd_link"
                (( synced++ ))
                print -P "  %F{green}→%f symlink  ${filename}"
            else
                (( skipped++ ))
            fi
        done

        if [[ -d "${hdd_cam}Proxy" ]]; then
            for proxy_file in "${hdd_cam}Proxy/"*; do
                [[ -f "$proxy_file" ]] || continue
                filename=$(basename "$proxy_file")
                ssd_proxy="${ssd_cam}/Proxy/${filename}"

                if [[ ! -e "$ssd_proxy" ]]; then
                    copy_with_progress "$proxy_file" "$ssd_proxy" "Proxy/${filename}"
                    (( synced++ ))
                else
                    (( skipped++ ))
                fi
            done
        fi
    done

    print -P "\n%F{green}%B✅ Готово:%b ${synced} новых, ${skipped} пропущено.%f\n"
    afplay /System/Library/Sounds/Glass.aiff 2>/dev/null || true

# ── ОБНОВИТЬ ─────────────────────────────────────────────────────────────────
elif [[ "$action" == *"Обновить"* ]]; then

    print -P "\n%B%F{cyan}Обновление Studio Tools...%f%b\n"
    if git -C "$STUDIO_DIR" pull; then
        cp "${STUDIO_DIR}/bin/proj" "$HOME/bin/proj" && chmod +x "$HOME/bin/proj"
        rm -f "$_UPDATE_FILE"
        local_ver=$(git -C "$STUDIO_DIR" rev-parse --short HEAD 2>/dev/null)
        print -P "\n%F{green}%B✅ Обновлено до ${local_ver}. Перезапусти proj.%f%b\n"
        exit 0
    else
        print -P "\n%F{red}✗ Ошибка. Проверь соединение или запусти: git -C ~/.studio-tools pull%f\n"
    fi

fi

done
