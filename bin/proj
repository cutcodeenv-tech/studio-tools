#!/usr/bin/env zsh

# ── КОНФИГ ──────────────────────────────────────────────────────────────────
STUDIO_DIR="$HOME/.studio-tools"
CONFIG_FILE="${STUDIO_DIR}/config"
TEMPLATE_DIR="${STUDIO_DIR}/template"
_UPDATE_FILE="${STUDIO_DIR}/.update_available"
_UPDATE_CACHE="${STUDIO_DIR}/.update_cache"

# ── OS detection ─────────────────────────────────────────────────────────────
case "$OSTYPE" in
    darwin*)       _OS="macos" ;;
    msys*|cygwin*) _OS="windows" ;;
    linux*)        _OS="linux" ;;
    *)             _OS="unknown" ;;
esac

_stat_size()  { [[ "$_OS" == "macos" ]] && stat -f%z "$1" 2>/dev/null || stat -c%s "$1" 2>/dev/null || echo 1; }
_stat_mtime() { [[ "$_OS" == "macos" ]] && stat -f%m "$1" 2>/dev/null || stat -c%Y "$1" 2>/dev/null || echo 0; }

if [[ ! -f "$CONFIG_FILE" ]]; then
    mkdir -p "$STUDIO_DIR"
    cat > "$CONFIG_FILE" <<'EOF'
SSD_PROJECTS_ROOT="/Volumes/01_Extreme SSD/[001] Projects"
HDD_SOURCES_ROOT="/Volumes/HDD_1"
PREMIERE_TEMPLATE="/Volumes/01_Extreme SSD/[003] Resurces/00_TEMPLATE1.prproj"
EOF
fi

source "$CONFIG_FILE"

[[ ! -d "$TEMPLATE_DIR" ]] && mkdir -p "$TEMPLATE_DIR"

_check_deps() {
    local _cache="${STUDIO_DIR}/.deps_ok"
    if [[ -f "$_cache" ]] && \
       (( $(date +%s) - $(_stat_mtime "$_cache") < 86400 )) && \
       command -v fzf &>/dev/null; then
        return 0
    fi

    case "$_OS" in
        macos)
            if ! command -v brew &>/dev/null; then
                print -P "%F{red}✗ Homebrew не установлен.%f"
                print -P "  /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
                return 1
            fi
            ;;
        windows)
            if ! command -v scoop &>/dev/null; then
                print -P "%F{cyan}  → Устанавливаю Scoop...%f"
                powershell -Command "Set-ExecutionPolicy RemoteSigned -Scope CurrentUser -Force; irm get.scoop.sh | iex"
                export PATH="$HOME/scoop/shims:$PATH"
            fi
            ;;
    esac

    local _any=false

    if ! command -v fzf &>/dev/null; then
        print -P "%F{cyan}  → Устанавливаю fzf...%f"
        case "$_OS" in
            macos)   brew install fzf ;;
            windows) scoop install fzf ;;
        esac
        _any=true
    fi
    if ! command -v mpv &>/dev/null; then
        print -P "%F{cyan}  → Устанавливаю mpv (аудио/видео)...%f"
        case "$_OS" in
            macos)   brew install mpv ;;
            windows) scoop install mpv ;;
        esac
        _any=true
    fi

    local _font_ok=false
    case "$_OS" in
        macos)
            for _d in "$HOME/Library/Fonts" "/Library/Fonts"; do
                ls "$_d" 2>/dev/null | grep -qi "JetBrainsMono.*Nerd" && { _font_ok=true; break; }
            done
            ;;
        windows)
            ls "$HOME/AppData/Local/Microsoft/Windows/Fonts" 2>/dev/null | grep -qi "JetBrainsMono" && _font_ok=true
            ;;
    esac
    if [[ "$_font_ok" == false ]]; then
        print -P "%F{cyan}  → Устанавливаю JetBrains Mono Nerd Font...%f"
        case "$_OS" in
            macos)   brew install --cask font-jetbrains-mono-nerd-font ;;
            windows) scoop bucket add nerd-fonts 2>/dev/null; scoop install JetBrainsMono-NF ;;
        esac
        _any=true
        print -P "%F{yellow}  ⚠  Выбери 'JetBrainsMono Nerd Font' в настройках терминала%f"
    fi

    [[ "$_any" == true ]] && print ""
    touch "$_cache"
    return 0
}
_check_deps || exit 1
# ────────────────────────────────────────────────────────────────────────────

PROJ_VERSION=$(git -C "$STUDIO_DIR" rev-parse --short HEAD 2>/dev/null || echo "?")

# ── ПРОГРЕСС-БАР ─────────────────────────────────────────────────────────────
copy_with_progress() {
    local src="$1" dst="$2" label="$3"
    local total=$(_stat_size "$src")
    local bar_width=30
    cp "$src" "$dst" &
    local cp_pid=$!
    while kill -0 $cp_pid 2>/dev/null; do
        local current=$(_stat_size "$dst")
        local pct=$(( current * 100 / total ))
        local filled=$(( pct * bar_width / 100 ))
        local bar=""
        for (( j=0; j<bar_width; j++ )); do
            (( j < filled )) && bar+="█" || bar+="░"
        done
        printf "\r  \033[33m⬇\033[0m  \033[90m[%s]\033[0m %3d%%  %s" "$bar" "$pct" "$label"
        sleep 0.15
    done
    wait $cp_pid; local _rc=$?
    local full_bar=$(printf '█%.0s' {1..$bar_width})
    (( _rc == 0 )) \
        && printf "\r  \033[32m✓\033[0m  \033[90m[%s]\033[0m 100%%  %s\n" "$full_bar" "$label" \
        || printf "\r  \033[31m✗\033[0m  копирование не удалось: %s\n" "$label"
    return $_rc
}

# ── ЗАПИСЬ В КОНФИГ ──────────────────────────────────────────────────────────
_config_set() {
    local key="$1" val="$2" tmpfile=$(mktemp) found=false
    while IFS= read -r line; do
        if [[ "$line" == "${key}="* ]]; then
            echo "${key}=\"${val}\"" >> "$tmpfile"; found=true
        else
            echo "$line" >> "$tmpfile"
        fi
    done < "$CONFIG_FILE"
    [[ "$found" == false ]] && echo "${key}=\"${val}\"" >> "$tmpfile"
    mv "$tmpfile" "$CONFIG_FILE"; source "$CONFIG_FILE"
}

_config_del() {
    grep -v "^${1}=" "$CONFIG_FILE" > "${CONFIG_FILE}.tmp"
    mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"; source "$CONFIG_FILE"
}

# ════════════════════════════════════════════════════════════════════════════
# СУБКОМАНДЫ
# ════════════════════════════════════════════════════════════════════════════

# ── proj new ─────────────────────────────────────────────────────────────────
cmd_new() {
    print -P "\n%B%F{cyan}┌─ Новый проект ─────────────────────────┐%f%b"
    print -P "%B%F{cyan}│%f%b Название: \c"; read PROJECT_NAME
    if [[ -z "$PROJECT_NAME" ]]; then
        print -P "%F{red}Отменено.%f\n"; return 1
    fi

    print -P "%B%F{cyan}│%f%b Камер (1-10) [2]: \c"; read CAM_COUNT
    if ! [[ "$CAM_COUNT" =~ ^[0-9]+$ ]] || (( CAM_COUNT < 1 || CAM_COUNT > 10 )); then
        CAM_COUNT=2
    fi
    print -P "%B%F{cyan}└────────────────────────────────────────┘%f%b"

    local DATE=$(date +%Y-%m-%d)
    local SAFE_NAME="${PROJECT_NAME// /_}"
    local PROJECT_FOLDER_NAME="${DATE}_${SAFE_NAME}"
    local SSD_ROOT="${SSD_PROJECTS_ROOT}/${PROJECT_FOLDER_NAME}"
    local HDD_ROOT="${HDD_SOURCES_ROOT}/${PROJECT_FOLDER_NAME}"

    if [[ -d "$SSD_ROOT" ]]; then
        print -P "\n%F{red}✗ Папка уже существует: ${SSD_ROOT}%f\n"; return 1
    fi

    print -P "\n%F{yellow}Создаю структуру...%f"

    cp -r "${TEMPLATE_DIR}/." "$SSD_ROOT/"
    print -P "  %F{green}✓%f  Папки SSD"

    if [[ -f "$PREMIERE_TEMPLATE" ]]; then
        cp "$PREMIERE_TEMPLATE" "${SSD_ROOT}/01_Project_Files/Premiere/${SAFE_NAME}.prproj"
        print -P "  %F{green}✓%f  Шаблон Premiere"
    else
        print -P "  %F{yellow}⚠%f  Шаблон Premiere не найден"
    fi

    if [[ ! -d "$HDD_SOURCES_ROOT" ]]; then
        print -P "  %F{yellow}⚠%f  HDD не смонтирован, камеры пропущены"
    else
        local ALPHABET=( {a..z} )
        for (( i=1; i<=CAM_COUNT; i++ )); do
            local CAM="Cam_${ALPHABET[$i]}"
            mkdir -p "${SSD_ROOT}/02_Sources/Video/${CAM}/Proxy"
            mkdir -p "${HDD_ROOT}/02_Sources/Video/${CAM}"
            print -P "  %F{green}✓%f  ${CAM}"
        done
    fi

    print -P "\n%F{green}%B✅ Готово:%b ${SSD_ROOT}%f"
    print -P "%F{cyan}│%f Открыть в Nimble Commander? [Y/n]: \c"; read OPEN_NC
    if [[ "$OPEN_NC" != "n" && "$OPEN_NC" != "N" ]]; then
        open -a "Nimble Commander" "$SSD_ROOT"
    fi
    print ""
}

# ── proj status ───────────────────────────────────────────────────────────────
cmd_status() {
    local chosen
    chosen=$(ls -1t "$SSD_PROJECTS_ROOT" 2>/dev/null | fzf \
        --prompt="  Проект > " \
        --height=40% \
        --border=rounded \
        --border-label=" Статус проекта " \
        --color="border:#5fafff,label:#5fafff,prompt:#5fafff,pointer:#ff875f" \
        --pointer="▶" --no-multi)
    [[ -z "$chosen" ]] && return

    local SSD_PROJECT="${SSD_PROJECTS_ROOT}/${chosen}"
    local HDD_PROJECT="${HDD_SOURCES_ROOT}/${chosen}"
    local total_hdd=0 total_symlinks=0 total_proxies=0

    print -P "\n%B%F{cyan}┌─ ${chosen}%f%b"

    for ssd_cam in "${SSD_PROJECT}/02_Sources/Video"/Cam_*/; do
        [[ -d "$ssd_cam" ]] || continue
        local cam_name=$(basename "$ssd_cam")
        local hdd_cam="${HDD_PROJECT}/02_Sources/Video/${cam_name}"
        local ssd_links=$(find "$ssd_cam" -maxdepth 1 -type l | wc -l | tr -d ' ')
        local hdd_files=0
        [[ -d "$hdd_cam" ]] && hdd_files=$(find "$hdd_cam" -maxdepth 1 -type f | wc -l | tr -d ' ')
        local proxy_count=$(find "${ssd_cam}Proxy" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')
        (( total_hdd += hdd_files ))
        (( total_symlinks += ssd_links ))
        (( total_proxies += proxy_count ))
        local icon
        if (( hdd_files > 0 && ssd_links == hdd_files )); then icon="%F{green}✓%f"
        elif (( ssd_links > 0 ));                           then icon="%F{yellow}~%f"
        else                                                      icon="%F{red}○%f"
        fi
        print -P "%B%F{cyan}│%f%b  ${icon}  ${cam_name}   HDD: ${hdd_files}   симлинки: ${ssd_links}   прокси: ${proxy_count}"
    done

    local ssd_size=$(du -sh "$SSD_PROJECT" 2>/dev/null | cut -f1)
    print -P "%B%F{cyan}│%f%b"
    print -P "%B%F{cyan}│%f%b  SSD: ${ssd_size}   исходников: ${total_hdd}   симлинков: ${total_symlinks}   прокси: ${total_proxies}"
    print -P "%B%F{cyan}└────────────────────────────────────────┘%f%b\n"
}

# ── proj sync ────────────────────────────────────────────────────────────────
cmd_sync() {
    print -P "\n%B%F{cyan}Sync Footage%f%b\n"

    if [[ ! -d "$HDD_SOURCES_ROOT" ]]; then
        print -P "%F{red}✗ HDD не смонтирован: ${HDD_SOURCES_ROOT}%f\n"; return 1
    fi

    local chosen
    chosen=$(ls -1t "$SSD_PROJECTS_ROOT" 2>/dev/null | fzf \
        --prompt="  Проект > " \
        --height=40% \
        --border=rounded \
        --border-label=" Выберите проект " \
        --color="border:#5fafff,label:#5fafff,prompt:#5fafff,pointer:#ff875f" \
        --pointer="▶" --no-multi)
    [[ -z "$chosen" ]] && { print -P "%F{red}Отменено.%f\n"; return; }

    local SSD_PROJECT="${SSD_PROJECTS_ROOT}/${chosen}"
    local HDD_PROJECT="${HDD_SOURCES_ROOT}/${chosen}"

    if [[ ! -d "$HDD_PROJECT" ]]; then
        print -P "%F{red}✗ Проект не найден на HDD: ${HDD_PROJECT}%f\n"; return 1
    fi

    print -P "%B▶ Проект:%b ${chosen}\n"
    local synced=0 skipped=0

    for hdd_cam in "${HDD_PROJECT}/02_Sources/Video"/Cam_*(N/); do
        local cam_name=$(basename "$hdd_cam")
        local ssd_cam="${SSD_PROJECT}/02_Sources/Video/${cam_name}"
        mkdir -p "${ssd_cam}/Proxy"
        print -P "%B%F{cyan}📁 ${cam_name}%f%b"

        for hdd_file in "${hdd_cam}/"*(N-.); do
            local filename=$(basename "$hdd_file")
            local ssd_link="${ssd_cam}/${filename}"
            if [[ ! -e "$ssd_link" && ! -L "$ssd_link" ]]; then
                ln -s "$hdd_file" "$ssd_link"
                (( synced++ ))
                print -P "  %F{green}→%f symlink  ${filename}"
            else
                (( skipped++ ))
            fi
        done

        for proxy_file in "${hdd_cam}/Proxy/"*(N-.); do
            local filename=$(basename "$proxy_file")
            local ssd_proxy="${ssd_cam}/Proxy/${filename}"
            if [[ ! -e "$ssd_proxy" ]]; then
                copy_with_progress "$proxy_file" "$ssd_proxy" "Proxy/${filename}" || true
                (( synced++ ))
            else
                (( skipped++ ))
            fi
        done
    done

    [[ "$_OS" == "macos" ]] && afplay /System/Library/Sounds/Glass.aiff 2>/dev/null || true
    print -P "\n%F{green}%B✅ Синхронизация завершена:%b ${synced} новых, ${skipped} уже было.%f\n"
}

# ── proj settings ────────────────────────────────────────────────────────────
cmd_settings() {
    while true; do
        source "$CONFIG_FILE"
        local _del_f=$(mktemp); : > "$_del_f"
        local _del_t="execute-silent(echo d > ${_del_f})+accept"

        local result
        result=$(printf \
            "  SSD_PROJECTS_ROOT    %s\n  HDD_SOURCES_ROOT     %s\n  PREMIERE_TEMPLATE    %s\n  Шаблон папок" \
            "$SSD_PROJECTS_ROOT" "$HDD_SOURCES_ROOT" "$PREMIERE_TEMPLATE" \
            | fzf \
            --prompt="  > " --height=12 --layout=reverse --border=rounded \
            --border-label=" Настройки " \
            --color="border:#5fafff,label:#5fafff,prompt:#5fafff,pointer:#ff875f" \
            --pointer="▶" --no-multi --expect="ctrl-r" \
            --bind="del:${_del_t}" --bind="bspace:${_del_t}" \
            --header="  Enter/Ctrl+R: изменить   Del: сбросить   Esc: назад")

        local is_delete=false
        [[ -s "$_del_f" ]] && is_delete=true
        rm -f "$_del_f"
        [[ -z "$result" ]] && break

        local lines=("${(@f)result}"); local selected="${lines[2]}"
        [[ -z "$selected" ]] && continue

        if [[ "$selected" == *"Шаблон папок"* ]]; then
            open -a "Nimble Commander" "$TEMPLATE_DIR"; continue
        fi

        local setting_key setting_val
        case "$selected" in
            *"SSD_PROJECTS_ROOT"*) setting_key="SSD_PROJECTS_ROOT"; setting_val="$SSD_PROJECTS_ROOT" ;;
            *"HDD_SOURCES_ROOT"*)  setting_key="HDD_SOURCES_ROOT";  setting_val="$HDD_SOURCES_ROOT"  ;;
            *"PREMIERE_TEMPLATE"*) setting_key="PREMIERE_TEMPLATE"; setting_val="$PREMIERE_TEMPLATE" ;;
        esac
        [[ -z "$setting_key" ]] && continue

        if $is_delete; then
            print -P "\n%F{yellow}Сбросить %B${setting_key}%b? [y/N]: \c"
            read CONFIRM </dev/tty
            if [[ "$CONFIRM" == "y" || "$CONFIRM" == "Y" ]]; then
                _config_del "$setting_key"
                print -P "  %F{red}✗%f  ${setting_key} удалён\n"
            fi
        else
            print -P "\n%B%F{cyan}┌─ ${setting_key}%f%b"
            print -P "%B%F{cyan}│%f%b \c"
            local new_val="$setting_val"
            vared new_val
            print -P "%B%F{cyan}└────────────────────────────────────────┘%f%b"
            if [[ -n "$new_val" && "$new_val" != "$setting_val" ]]; then
                _config_set "$setting_key" "$new_val"
                print -P "  %F{green}✓%f  Сохранено\n"
            fi
        fi
    done
}

# ── launcher (Cmd+P из NC) ────────────────────────────────────────────────────
cmd_menu() {
    local action
    action=$(printf \
        "  Новый проект\n  Синхронизировать footage\n  Статус проекта\n  Настройки\n  Шаблон папок\n  Обновить Studio Tools" \
        | fzf \
        --prompt="  > " --height=11 --layout=reverse --border=rounded \
        --border-label=" Studio Tools " \
        --color="border:#5fafff,label:#5fafff,prompt:#5fafff,pointer:#ff875f" \
        --pointer="▶" --no-multi)
    [[ -z "$action" ]] && return
    case "$action" in
        *"Новый"*)     cmd_new ;;
        *"Синхрон"*)   cmd_sync ;;
        *"Статус"*)    cmd_status ;;
        *"Настройки"*) cmd_settings ;;
        *"Шаблон"*)    open -a "Nimble Commander" "$TEMPLATE_DIR" ;;
        *"Обновить"*)  cmd_update ;;
    esac
}

# ── proj update ───────────────────────────────────────────────────────────────
cmd_update() {
    print -P "\n%B%F{cyan}Обновление Studio Tools...%f%b\n"
    if ! git -C "$STUDIO_DIR" pull; then
        print -P "\n%F{red}✗ Ошибка. Запусти: git -C ~/.studio-tools pull%f\n"
        return 1
    fi

    local new_proj="${STUDIO_DIR}/bin/proj"
    local cur_proj="$HOME/bin/proj"

    # Если бинарь изменился — копируем и перезапускаем новую версию для деплоя
    if ! diff -q "$new_proj" "$cur_proj" &>/dev/null; then
        cp "$new_proj" "$cur_proj" && chmod +x "$cur_proj"
        print -P "  %F{green}✓%f  bin/proj (новая версия — перезапускаю деплой)"
        exec "$cur_proj" _deploy
    fi

    # Бинарь уже актуален — деплоим остальное
    "$cur_proj" _deploy
}

cmd_deploy() {
    if [[ -f "${STUDIO_DIR}/bin/sf" ]]; then
        cp "${STUDIO_DIR}/bin/sf" "$HOME/bin/sf" && chmod +x "$HOME/bin/sf"
        print -P "  %F{green}✓%f  bin/sf"
    fi

    if [[ "$_OS" == "macos" && -f "${STUDIO_DIR}/nimble-commander/minfo.applescript" ]]; then
        osacompile -o "$HOME/bin/minfo.app" "${STUDIO_DIR}/nimble-commander/minfo.applescript" 2>/dev/null \
            && print -P "  %F{green}✓%f  minfo.app" \
            || print -P "  %F{yellow}⚠%f  minfo.app не скомпилирован"
    fi

    if [[ "$_OS" == "macos" ]]; then
        local _nc_cfg="$HOME/Library/Application Support/Nimble Commander/Config/Config.json"
        local _nc_py="${STUDIO_DIR}/nimble-commander/tools.py"
        if [[ -f "$_nc_py" && -f "$_nc_cfg" ]]; then
            python3 "$_nc_py" "$_nc_cfg" \
                && print -P "  %F{green}✓%f  Nimble Commander (тема + настройки)" \
                || print -P "  %F{yellow}⚠%f  NC: закрой приложение и повтори proj update"
        fi
    fi

    rm -f "$_UPDATE_FILE"
    local ver=$(git -C "$STUDIO_DIR" rev-parse --short HEAD 2>/dev/null)
    print -P "\n%F{green}%B✅ Обновлено до ${ver}. Перезапусти NC.%f%b\n"
}

# ── proj help ────────────────────────────────────────────────────────────────
cmd_help() {
    print -P "
%B%F{cyan}proj ${PROJ_VERSION}%f%b — Studio Tools

  %Bproj%b                Открыть проекты в Nimble Commander
  %Bproj new%b            Создать новый проект
  %Bproj status%b         Статус проекта (HDD / симлинки / прокси)
  %Bproj sync%b           Синхронизировать footage с HDD
  %Bproj settings%b       Настройки (пути, шаблон папок)
  %Bproj template%b       Открыть шаблон папок в Nimble Commander
  %Bproj update%b         Обновить studio-tools

%F{240}  Из NC: Cmd+N — новый проект   Cmd+Shift+S — синхронизация   Cmd+Shift+I — статус   Cmd+P — меню%f
"
}

# ════════════════════════════════════════════════════════════════════════════
# РОУТЕР
# ════════════════════════════════════════════════════════════════════════════

# Фоновая проверка обновлений
(
    if [[ ! -f "$_UPDATE_CACHE" ]] || \
       (( $(date +%s) - $(_stat_mtime "$_UPDATE_CACHE") > 21600 )); then
        touch "$_UPDATE_CACHE"
        if git -C "$STUDIO_DIR" fetch origin main --quiet 2>/dev/null; then
            local behind=$(git -C "$STUDIO_DIR" rev-list HEAD..origin/main --count 2>/dev/null)
            (( behind > 0 )) && echo "$behind" > "$_UPDATE_FILE" || rm -f "$_UPDATE_FILE"
        fi
    fi
) &>/dev/null &

case "$1" in
    new)      cmd_new ;;
    status)   cmd_status ;;
    sync)     cmd_sync ;;
    settings) cmd_settings ;;
    template) open -a "Nimble Commander" "$TEMPLATE_DIR" ;;
    menu)     cmd_menu ;;
    update)   cmd_update ;;
    _deploy)  cmd_deploy ;;
    help|-h|--help) cmd_help ;;
    "")
        [[ -f "$_UPDATE_FILE" ]] && \
            print -P "%F{yellow}  ⬆  Доступно обновление → proj update%f"
        open -a "Nimble Commander" "$SSD_PROJECTS_ROOT"
        ;;
    *)
        print -P "%F{red}Неизвестная команда: $1%f"
        cmd_help; exit 1
        ;;
esac
